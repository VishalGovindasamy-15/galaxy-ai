# Galaxy AI Environment Variables
# Copy this to .env and fill in values for cloud model providers (optional)

# ─── Cloud Model API Keys (OPTIONAL — Galaxy works fully local with Ollama) ───
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=

# ─── Custom/Self-Hosted Model Endpoints ───
CUSTOM_MODEL_BASE_URL=
CUSTOM_MODEL_API_KEY=

# ─── Infrastructure (Optional upgrades — Galaxy uses SQLite + in-memory by default) ───
# REDIS_URL=redis://localhost:6379/0
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/galaxy

# ─── Galaxy Settings ───
GALAXY_LOG_LEVEL=INFO
GALAXY_STUDIO_PORT=8420
